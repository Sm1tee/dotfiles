/** ********** Fonts ********** **/
/* Глобальный селектор (*), применяет стили ко всем элементам */
* {
  /* Устанавливает шрифт "Widock TRIAL" для всего текста в wlogout */
  font-family: "Widock TRIAL";
  /* Устанавливает размер шрифта для всего текста (влияет на размер кнопки, если текст отображается или учитывается GTK при расчете минимального размера) */
  font-size: 20px;
  /* Устанавливает жирное начертание для всего текста */
  font-weight: bold;
}

/** ********** Main Window ********** **/
/* Селектор для основного окна wlogout */
window {
  /* Устанавливает фон окна полностью прозрачным, чтобы был виден рабочий стол */
  background-color: transparent;
}

/** ********** Buttons ********** **/
/* Селектор для всех элементов <button> */
button {
  /* Цвет фона кнопки в обычном состоянии */
  background-color: #161925;
  /* Цвет текста на кнопке (даже если текст скрыт или не задан в layout, свойство может присутствовать) */
  color: #cdd6f4;
  /* Устанавливает границу: толщина 2px, сплошная линия (solid - по умолчанию), цвет #282838 */
  border: 2px solid #282838;
  /* Радиус скругления углов кнопки */
  border-radius: 20px;
  /* Запрещает повторение фонового изображения (иконки), если оно меньше кнопки */
  background-repeat: no-repeat;
  /* Центрирует фоновое изображение (иконку) внутри кнопки */
  background-position: center;
  /* Масштабирует фоновое изображение (иконку) до 25% от размера контейнера (кнопки).
     Примечание: Это процент от размера кнопки, а не фиксированный размер иконки. */
  background-size: 25%;
  /* Добавляет плавный переход для всех изменяемых свойств (например, background-color при наведении)
     длительностью 0.2 секунды с эффектом замедления в начале и конце (ease-in-out). */
  transition: all 0.2s ease-in-out;
  /* Сюда можно добавить padding, min-width, min-height для контроля размера, если потребуется */
}

/* Селектор для кнопок, когда они находятся в фокусе (выбраны клавиатурой),
   активны (нажаты мышью) или когда на них наведен курсор мыши */
button:focus,
button:active,
button:hover {
  /* Цвет текста кнопки при наведении/активации/фокусе */
  color: #FFFFFF;
  /* Цвет фона кнопки при наведении/активации/фокусе */
  background-color: #b4befe;
  /* Убирает стандартную рамку фокуса (outline), которая может появляться вокруг кнопки при выборе */
  outline-style: none;
}

/** ********** Icons ********** **/
/* ID-селектор для конкретной кнопки с label="lock" в файле layout */
#lock {
  /* Устанавливает фоновое изображение для кнопки блокировки.
     GTK (через CSS) пытается сначала загрузить файл из локального пути "icons/lock.png"
     (путь может быть относителен к CSS файлу или другой конфигурации).
     Если первый URL не найден или недопустим, используется второй URL
     - стандартный путь "/usr/share/wlogout/icons/lock.png". */
  background-image: image(url("icons/lock.png"), url("/usr/share/wlogout/icons/lock.png"));
}

/* ID-селектор для кнопки с label="logout" */
#logout {
  /* Устанавливает фоновое изображение для кнопки выхода, используя тот же принцип поиска с двумя URL */
  background-image: image(url("icons/logout.png"), url("/usr/share/wlogout/icons/logout.png"));
}

/* #suspend - Удалено */
/* Обычный CSS комментарий, указывающий, что стили для кнопки suspend были удалены из этого файла */

/* #hibernate - Удалено */
/* Обычный CSS комментарий, указывающий, что стили для кнопки hibernate были удалены */

/* ID-селектор для кнопки с label="shutdown" */
#shutdown {
  /* Устанавливает фоновое изображение для кнопки выключения */
  background-image: image(url("icons/shutdown.png"), url("/usr/share/wlogout/icons/shutdown.png"));
}

/* ID-селектор для кнопки с label="reboot" */
#reboot {
  /* Устанавливает фоновое изображение для кнопки перезагрузки */
  background-image: image(url("icons/reboot.png"), url("/usr/share/wlogout/icons/reboot.png"));
}