e","Machine Learning"],"activationEvents":["onDebugInitialConfigurations","onLanguage:python","onDebugResolve:python","onCommand:python.copilotSetupTests","workspaceContains:mspythonconfig.json","workspaceContains:pyproject.toml","workspaceContains:Pipfile","workspaceContains:setup.py","workspaceContains:requirements.txt","workspaceContains:manage.py","workspaceContains:app.py","workspaceContains:.venv","workspaceContains:.conda"],"main":"./out/client/extension","browser":"./dist/extension.browser.js","l10n":"./l10n","contributes":{"problemMatchers":[{"name":"python","owner":"python","source":"python","fileLocation":"autoDetect","pattern":[{"regexp":"^.*File \\\"([^\\\"]|.*)\\\", line (\\d+).*","file":1,"line":2},{"regexp":"^\\s*(.*)\\s*$"},{"regexp":"^\\s*(.*Error.*)$","message":1}]}],"walkthroughs":[{"id":"pythonWelcome","title":"Начало работы с разработкой на Python","description":"Ваши первые шаги по настройке проекта Python с использованием всех мощных инструментов и функций, которые может предложить расширение Python!","when":"workspacePlatform != webworker","steps":[{"id":"python.createPythonFolder","title":"Открыть папку проекта Python","description":"[Откройте](command:workbench.action.files.openFolder) или создайте папку проекта.\n[Открыть папку проекта](command:workbench.action.files.openFolder)","media":{"svg":"resources/walkthrough/open-folder.svg","altText":"Открытие файла или папки Python с помощью проекта Python."},"when":"workspaceFolderCount = 0"},{"id":"python.createPythonFile","title":"Создание файла Python","description":"[Откройте](command:toSide:workbench.action.files.openFile) или [создайте](command:toSide:workbench.action.files.newUntitledFile?%7B%22languageId%22%3A%22python%22%7D) файл Python — обязательно сохраните его с расширением PY.\n[Создать файл Python](command:toSide:workbench.action.files.newUntitledFile?%7B%22languageId%22%3A%22python%22%7D)","media":{"svg":"resources/walkthrough/open-folder.svg","altText":"Открытие файла или папки Python с помощью проекта Python."}},{"id":"python.installPythonWin8","title":"Установка Python","description":"Для установки расширения Python требуется установить Python. Установите Python [с python.org](https://www.python.org/downloads).\n\n[Установить Python](https://www.python.org/downloads)\n","media":{"markdown":"resources/walkthrough/install-python-windows-8.md"},"when":"workspacePlatform == windows && showInstallPythonTile"},{"id":"python.installPythonMac","title":"Установка Python","description":"Для установки расширения Python требуется установить Python. Установите Python 3 с помощью терминала.\n[Установить Python с помощью Brew](command:python.installPythonOnMac)\n","media":{"markdown":"resources/walkthrough/install-python-macos.md"},"when":"workspacePlatform == mac && showInstallPythonTile","command":"workbench.action.terminal.new"},{"id":"python.installPythonLinux","title":"Установка Python","description":"Для установки расширения Python требуется установить Python. Установите Python 3 с помощью терминала.\n[Установить Python с помощью терминала](command:python.installPythonOnLinux)\n","media":{"markdown":"resources/walkthrough/install-python-linux.md"},"when":"workspacePlatform == linux && showInstallPythonTile","command":"workbench.action.terminal.new"},{"id":"python.createEnvironment","title":"Выбор или создание среды Python","description":"Создайте среду для проекта Python или используйте [выбор интерпретатора Python](command:python.setInterpreter) для выбора существующей среды.\n[Создать среду](command:python.createEnvironment)\n**Совет**. Выполните команду \"Python: Create Environment\" в [палитре команд](command:workbench.action.showCommands).","media":{"svg":"resources/walkthrough/create-environment.svg","altText":"Создание среды Python из палитры команд"}},{"id":"python.runAndDebug","title":"Запуск и отладка файла Python","description":"Откройте файл Python и нажмите кнопку \"Воспроизвести\" в правом верхнем углу редактора или нажмите клавишу F5 при выборе файла и выберите \"Файл Python\", чтобы запустить отладчик. \n  \n[Дополнительные сведения](https://code.visualstudio.com/docs/python/python-tutorial#_run-hello-world)","media":{"svg":"resources/walkthrough/rundebug2.svg","altText":"Запуск и отладка в VS Code с помощью клавиши F5 или кнопки воспроизведения в правом верхнем углу."}},{"id":"python.learnMoreWithDS","title":"Продолжайте изучать.","description":"🎨 Просмотрите все функции, которые может предложить расширение Python, выполнив поиск \"Python\" на [палитре команд](command:workbench.action.showCommands). \n 📈 Узнайте больше о начале работы с [обработкой и анализом данных](command:workbench.action.openWalkthrough?%7B%22category%22%3A%22ms-python.python%23pythonDataScienceWelcome%22%2C%22step%22%3A%22ms-python.python%23python.createNewNotebook%22%7D) в Python. \n ✨ Просмотрите [заметки о выпуске](https://aka.ms/AA8dxtb), чтобы узнать о новейших функциях. \n \n[Просмотрите учебник по Python](https://aka.ms/AA8dqti)","media":{"altText":"Изображение, представляющее нашу страницу документации и ресурсы списка рассылки.","svg":"resources/walkthrough/learnmore.svg"}}]},{"id":"pythonDataScienceWelcome","title":"Начало работы с Python для обработки и анализа данных","description":"Ваши первые шаги по началу работы с проектом по обработке и анализу данных Python!","when":"false","steps":[{"id":"python.installJupyterExt","title":"Установка расширения Jupyter","description":"Если вы еще этого не сделали, установите [расширение Jupyter](command:workbench.extensions.search?\" ms-toolsai.jupyter\") для использования всех возможностей записных книжек в VS Code!\n \n[Поиск расширения Jupyter](command:workbench.extensions.search?\" ms-toolsai.jupyter\")","media":{"svg":"resources/walkthrough/data-science.svg","altText":"Создание новой записной книжки Jupyter"}},{"id":"python.createNewNotebook","title":"Создайте или откройте Jupyter Notebook.","description":"Щелкните правой кнопкой мыши в проводнике и создайте новый файл с расширением IPYNB. Или откройте [палитру команд](command:workbench.action.showCommands) и выполните команду \n\"Jupyter: Create New Blank Notebook\".\n[Создать новую записную книжку Jupyter Notebook](command:toSide:jupyter.createnewnotebook)\n Если у вас уже есть проект, вы также можете [открыть папку](command:workbench.action.files.openFolder) и (или) клонировать проект из GitHub: [клонировать репозиторий Git](command:toSide:git.clone).","media":{"svg":"resources/walkthrough/create-notebook.svg","altText":"Создание новой записной книжки Jupyter"},"completionEvents":["onCommand:jupyter.createnewnotebook","onCommand:workbench.action.files.openFolder","onCommand:workbench.action.files.openFileFolder"]},{"id":"python.openInteractiveWindow","title":"Открытие интерактивного окна Python","description":"Интерактивное окно Python — это оболочка Python, в которой можно выполнять код Python и просматривать результаты его выполнения. Вы можете создавать ячейки в файле Python, введя \"#%%\".\n \nЧтобы в любое время открыть интерактивное окно, откройте [палитру команд] (command:workbench.action.showCommands) и выполните команду \n\"Jupyter: Create Interactive Window\".\n[Открыть интерактивное окно](command:jupyter.createnewinteractive)","media":{"svg":"resources/walkthrough/interactive-window.svg","altText":"Открытие интерактивного окна Python"},"completionEvents":["onCommand:jupyter.createnewinteractive"]},{"id":"python.dataScienceLearnMore","title":"Подробнее","description":"📒 Ознакомьтесь с [ расширением Jupyter](command:workbench.extensions.search?\" ms-toolsai.jupyter\"), выполнив поиск Jupyter в [палитре команд](command:workbench.action.showCommands). \n 🏃🏻 Узнайте больше о функциях в наших [руководствах](https://aka.ms/AAdjzpd).  \n[Дополнительные сведения](https://aka.ms/AAdar6q)","media":{"svg":"resources/walkthrough/learnmore.svg","altText":"Изображение, представляющее нашу страницу документации и ресурсы списка рассылки."}}]}],"breakpoints":[{"language":"html"},{"language":"jinja"},{"language":"python"},{"language":"django-html"},{"language":"django-txt"}],"commands":[{"title":{"value":"Новый файл Python","original":"New Python File"},"shortTitle":"Файл Python","category":"Python","command":"python.createNewFile"},{"category":"Python","command":"python.analysis.restartLanguageServer","title":{"value":"Перезапустить языковой сервер","original":"Restart Language Server"}},{"category":"Python","command":"python.clearCacheAndReload","title":{"value":"Очистить кэш и перезагрузить окно","original":"Clear Cache and Reload Window"}},{"category":"Python","command":"python.clearWorkspaceInterpreter","title":{"value":"Очистить параметр интерпретатора рабочей области","original":"Clear Workspace Interpreter Setting"}},{"category":"Python","command":"python.configureTests","title":{"value":"Настройка тестов","original":"Configure Tests"}},{"category":"Python","command":"python.createTerminal","title":{"value":"Создать терминал","original":"Create Terminal"}},{"category":"Python","command":"python.createEnvironment","title":{"value":"Создать среду...","original":"Create Environment..."}},{"category":"Python","command":"python.createEnvironment-button","title":{"value":"Создать среду...","original":"Create Environment..."}},{"category":"Python","command":"python.execInTerminal","title":{"value":"Запустить файл Python в терминале","original":"Run Python File in Terminal"}},{"category":"Python","command":"python.execInTerminal-icon","icon":"$(play)","title":{"value":"Запуск файла Python","original":"Run Python File"}},{"category":"Python","command":"python.execInDedicatedTerminal","icon":"$(play)","title":{"value":"Запустить файл Python на выделенном терминале","original":"Run Python File in Dedicated Terminal"}},{"category":"Python","command":"python.execSelectionInDjangoShell","title":{"value":"Запустить выделение или строку в оболочке Django","original":"Run Selection/Line in Django Shell"}},{"category":"Python","command":"python.execSelectionInTerminal","title":{"value":"Запустить выделение или строку в терминале Python","original":"Run Selection/Line in Python Terminal"}},{"category":"Python","command":"python.execInREPL","title":{"value":"Запуск выделения или строки в собственном Python REPL","original":"Run Selection/Line in Native Python REPL"}},{"category":"Python","command":"python.reportIssue","title":{"value":"Сообщить о проблеме...","original":"Report Issue..."}},{"category":"Test","command":"testing.reRunFailTests","icon":"$(run-errors)","title":{"value":"Повторить запуск неудачных тестов","original":"Rerun Failed Tests"}},{"category":"Python","command":"python.setInterpreter","title":{"value":"Выбор интерпретатора","original":"Select Interpreter"}},{"category":"Python","command":"python.startREPL","title":{"value":"Запуск REPL для терминала","original":"Start Terminal REPL"}},{"category":"Python","command":"python.startNativeREPL","title":{"value":"Запуск собственной REPL для REPL","original":"Start Native Python REPL"}},{"category":"Python","command":"python.viewLanguageServerOutput","enablement":"python.hasLanguageServerOutputChannel","title":{"value":"Показать выходные данные языкового сервера","original":"Show Language Server Output"}},{"category":"Python","command":"python.viewOutput","icon":{"dark":"resources/dark/repl.svg","light":"resources/light/repl.svg"},"title":{"value":"Показать выходные данные","original":"Show Output"}},{"category":"Python","command":"python.installJupyter","title":{"value":"Установка расширения Jupyter","original":"Install the Jupyter extension"}}],"configuration":{"properties":{"python.activeStateToolPath":{"default":"state","description":"Путь к исполняемому файлу State Tool для сред выполнения ActiveState (версия 0.36+).","scope":"machine-overridable","type":"string"},"python.autoComplete.extraPaths":{"default":[],"description":"Список путей к библиотекам и подобным ресурсам, которые необходимо импортировать с помощью подсистемы автозаполнения. Например, при использовании пакета SDK Google App пути не указаны в системном пути, поэтому их необходимо добавить в этот список.","scope":"resource","type":"array","uniqueItems":true},"python.createEnvironment.contentButton":{"default":"hide","markdownDescription":"Отображает или скрывает кнопку \"Создать среду\" в редакторе для файла \"requirements.txt\" и для других файлов зависимостей.","scope":"machine-overridable","type":"string","enum":["show","hide"]},"python.createEnvironment.trigger":{"default":"prompt","markdownDescription":"Определите, требуется ли создание среды для текущего проекта","scope":"machine-overridable","type":"string","enum":["off","prompt"]},"python.condaPath":{"default":"","description":"Путь к исполняемому файлу Conda, используемому для активации (версия 4.4 и более поздние).","scope":"machine","type":"string"},"python.defaultInterpreterPath":{"default":"python","markdownDescription":"Путь к каталогу Python по умолчанию, используемый при первой загрузке расширения, больше не используется после выбора интерпретатора для рабочей области. Сведения о том, когда он используется, см. [здесь](https://aka.ms/AAfekmf).","scope":"machine-overridable","type":"string"},"python.envFile":{"default":"${workspaceFolder}/.env","description":"Абсолютный путь к файлу, содержащему определения переменных среды.","scope":"resource","type":"string"},"python.experiments.enabled":{"default":true,"description":"Включает эксперименты A/B-тестов в расширения Python. Если этот параметр включен, вас могут включить в предлагаемые улучшения и (или) функции.","scope":"window","type":"boolean"},"python.experiments.optInto":{"default":[],"markdownDescription":"Список экспериментов, в которых следует участвовать. Если он пуст, пользователю назначаются группы экспериментов по умолчанию. Дополнительные сведения см. [здесь](https://github.com/microsoft/vscode-python/wiki/AB-Experiments).","items":{"enum":["All","pythonSurveyNotification","pythonPromptNewToolsExt","pythonTerminalEnvVarActivation","pythonDiscoveryUsingWorkers","pythonTestAdapter","pythonREPLSmartSend"],"enumDescriptions":["Объединенный список всех экспериментов.","Обозначает эксперимент с уведомлением опроса Python.","Обозначает эксперимент Python Prompt New Tools Extension.","Включает использование переменных сред для активации терминалов вместо отправки команд активации.","Дает возможность использовать рабочие потоки для ресурсоемких вычислений при обнаружении интерпретаторов.","Обозначает эксперимент адаптера теста Python.","Обозначает эксперимент интеллектуальной отправки Python REPL."]},"scope":"window","type":"array","uniqueItems":true},"python.experiments.optOutFrom":{"default":[],"markdownDescription":"Список экспериментов, от которые требуется отказаться. Если он пуст, пользователю назначаются группы экспериментов по умолчанию. Дополнительные сведения см. [здесь](https://github.com/microsoft/vscode-python/wiki/AB-Experiments).","items":{"enum":["All","pythonSurveyNotification","pythonPromptNewToolsExt","pythonTerminalEnvVarActivation","pythonDiscoveryUsingWorkers","pythonTestAdapter","pythonREPLSmartSend"],"enumDescriptions":["Объединенный список всех экспериментов.","Обозначает эксперимент с уведомлением опроса Python.","Обозначает эксперимент Python Prompt New Tools Extension.","Включает использование переменных сред для активации терминалов вместо отправки команд активации.","Дает возможность использовать рабочие потоки для ресурсоемких вычислений при обнаружении интерпретаторов.","Обозначает эксперимент адаптера теста Python.","Обозначает эксперимент интеллектуальной отправки Python REPL."]},"scope":"window","type":"array","uniqueItems":true},"python.globalModuleInstallation":{"default":false,"description":"Следует ли устанавливать модули Python глобально, если среда не используется.","scope":"resource","type":"boolean"},"python.languageServer":{"default":"Default","description":"Определяет тип языкового сервера.","enum":["Default","Jedi","Pylance","None"],"enumDescriptions":["Автоматический выбор языкового сервера: Pylance, если он установлен и доступен, в противном случае откат к Jedi.","Использование Jedi c протоколом LSP в качестве языкового сервера.","Использование Pylance в качестве языкового сервера.","Отключение возможностей языкового сервера."],"scope":"window","type":"string"},"python.interpreter.infoVisibility":{"default":"onPythonRelated","description":"Управляет отображением сведений о выбранном интерпретаторе в строке состояния.","enum":["never","onPythonRelated","always"],"enumDescriptions":["Никогда не отображать сведения.","Отображать сведения, только если открыты файлы, связанные с Python.","Всегда отображать сведения."],"scope":"machine","type":"string"},"python.logging.level":{"default":"error","deprecationMessage":"Этот параметр устарел. Используйте команду \"Developer: Set Log Level...\" для задания уровня ведения журнала.","description":"Уровень ведения журнала для журналов расширения, значение по умолчанию — \"error\"","enum":["debug","error","info","off","warn"],"scope":"machine","type":"string"},"python.missingPackage.severity":{"default":"Hint","description":"Настройка уровня серьезности отсутствующих пакетов в requirements.txt или pyproject.toml","enum":["Error","Hint","Information","Warning"],"scope":"resource","type":"string"},"python.locator":{"default":"js","description":"[Экспериментальный параметр] Выберите реализацию локаторов окружения. Это экспериментальный параметр, используемый при проверке расположения собственной среды.","enum":["js","native"],"tags":["onExP","preview"],"scope":"machine","type":"string"},"python.pipenvPath":{"default":"pipenv","description":"Путь к исполняемому файлу pipenv, используемому для активации.","scope":"machine-overridable","type":"string"},"python.poetryPath":{"default":"poetry","description":"Путь к исполняемому файлу poetry.","scope":"machine-overridable","type":"string"},"python.pixiToolPath":{"default":"pixi","description":"Путь к исполняемому файлу pixi.","scope":"machine-overridable","type":"string"},"python.terminal.activateEnvInCurrentTerminal":{"default":false,"description":"Активация среды Python в текущем терминале при загрузке расширения.","scope":"resource","type":"boolean"},"python.terminal.activateEnvironment":{"default":true,"description":"Активация среды Python во всех созданных терминалах.","scope":"resource","type":"boolean"},"python.terminal.executeInFileDir":{"default":false,"description":"При выполнении файла в терминале следует ли делать это в каталоге файла, а не в текущей открытой папке.","scope":"resource","type":"boolean"},"python.terminal.focusAfterLaunch":{"default":false,"description":"Следует ли переключить фокус курсора на терминал при запуске терминала Python.","scope":"resource","type":"boolean"},"python.terminal.launchArgs":{"default":[],"description":"Аргументы запуска Python, которые будут использоваться при выполнении файла в терминале.","scope":"resource","type":"array"},"python.terminal.shellIntegration.enabled":{"default":false,"markdownDescription":"Включение [интеграции оболочки](https://code.visualstudio.com/docs/terminal/shell-integration) для терминалов, на которые запущен python. Интеграция с оболочкой расширяет возможности терминала, позволяя, помимо прочего, добавлять украшения для команд, запускать последние команды, улучшая доступность.","scope":"resource","type":"boolean","tags":["preview"]},"python.REPL.enableREPLSmartSend":{"default":true,"description":"Переключение интеллектуальной отправки для REPL Python. Функция интеллектуальной отправки дает возможность отправлять наименьший пригодный для выполнения блок кода в REPL при нажатии клавиш SHIFT+ВВОД. При этом курсор перемещается соответствующим образом.","scope":"resource","type":"boolean"},"python.REPL.sendToNativeREPL":{"default":false,"description":"Переключить для отправки кода в Python REPL вместо терминала при выполнении. Включение этого параметра приведет к изменению поведения функции интеллектуальной отправки и выполнения выделения/строки в контекстном меню.","scope":"resource","type":"boolean","tags":["onExP","preview"]},"python.REPL.provideVariables":{"default":true,"description":"Переключите, чтобы предоставить переменные для представления переменных REPL для собственного REPL.","scope":"resource","type":"boolean"},"python.testing.autoTestDiscoverOnSaveEnabled":{"default":true,"description":"Включите обнаружение автоматических тестов при сохранении файла теста.","scope":"resource","type":"boolean"},"python.testing.autoTestDiscoverOnSavePattern":{"default":"**/*.py","description":"Шаблон GLOB-объекта, используемый для определения файлов, используемых autoTestDiscoverOnSaveEnabled.","scope":"resource","type":"string"},"python.testing.cwd":{"default":null,"description":"Необязательный рабочий каталог для тестов.","scope":"resource","type":"string"},"python.testing.debugPort":{"default":3000,"description":"Номер порта, используемый для отладки тестов.","scope":"resource","type":"number"},"python.testing.promptToConfigure":{"default":true,"description":"Запрос на настройку платформы тестирования при обнаружении потенциальных каталогов тестов.","scope":"resource","type":"boolean"},"python.testing.pytestArgs":{"default":[],"description":"Аргументы переданы. Каждый аргумент является отдельным элементом в массиве.","items":{"type":"string"},"scope":"resource","type":"array"},"python.testing.pytestEnabled":{"default":false,"description":"Включить тестирование с помощью pytest.","scope":"resource","type":"boolean"},"python.testing.pytestPath":{"default":"pytest","description":"Путь к pytest. Вы можете использовать настраиваемую версию pytest, изменив эту настройку и включив полный путь.","scope":"machine-overridable","type":"string"},"python.testing.unittestArgs":{"default":["-v","-s",".","-p","*test*.py"],"description":"Аргументы переданы. Каждый аргумент является отдельным элементом в массиве.","items":{"type":"string"},"scope":"resource","type":"array"},"python.testing.unittestEnabled":{"default":false,"description":"Включить тестирование с помощью unittest.","scope":"resource","type":"boolean"},"python.venvFolders":{"default":[],"description":"Папки в домашнем каталоге для поиска виртуальных сред (по умолчанию поддерживают pyenv, direnv и virtualenvwrapper).","items":{"type":"string"},"scope":"machine","type":"array","uniqueItems":true},"python.venvPath":{"default":"","description":"Путь к папке со списком виртуальных сред (например, ~/.pyenv, ~/Envs, ~/.virtualenvs).","scope":"machine","type":"string"}},"title":"Python","type":"object"},"debuggers":[{"configurationAttributes":{"attach":{"properties":{"connect":{"label":"Attach by connecting to debugpy over a socket.","properties":{"host":{"default":"127.0.0.1","description":"Hostname or IP address to connect to.","type":"string"},"port":{"description":"Port to connect to.","type":"number"}},"required":["port"],"type":"object"},"debugAdapterPath":{"description":"Path (fully qualified) to the python debug adapter executable.","type":"string"},"django":{"default":false,"description":"Django debugging.","type":"boolean"},"host":{"default":"127.0.0.1","description":"Hostname or IP address to connect to.","type":"string"},"jinja":{"default":null,"description":"Jinja template debugging (e.g. Flask).","enum":[false,null,true]},"justMyCode":{"default":true,"description":"If true, show and debug only user-written code. If false, show and debug all code, including library calls.","type":"boolean"},"listen":{"label":"Attach by listening for incoming socket connection from debugpy","properties":{"host":{"default":"127.0.0.1","description":"Hostname or IP address of the interface to listen on.","type":"string"},"port":{"description":"Port to listen on.","type":"number"}},"required":["port"],"type":"object"},"logToFile":{"default":false,"description":"Enable logging of debugger events to a log file.","type":"boolean"},"pathMappings":{"default":[],"items":{"label":"Path mapping","properties":{"localRoot":{"default":"${workspaceFolder}","label":"Local source root.","type":"string"},"remoteRoot":{"default":"","label":"Remote source root.","type":"string"}},"required":["localRoot","remoteRoot"],"type":"object"},"label":"Path mappings.","type":"array"},"port":{"description":"Port to connect to.","type":"number"},"processId":{"anyOf":[{"default":"${command:pickProcess}","description":"Use process picker to select a process to attach, or Process ID as integer.","enum":["${command:pickProcess}"]},{"description":"ID of the local process to attach to.","type":"integer"}]},"redirectOutput":{"default":true,"description":"Redirect output.","type":"boolean"},"showReturnValue":{"default":true,"description":"Show return value of functions when stepping.","type":"boolean"},"subProcess":{"default":false,"description":"Whether to enable Sub Process debugging","type":"boolean"}}},"launch":{"properties":{"args":{"default":[],"description":"Command line arguments passed to the program.","items":{"type":"string"},"type":["array","string"]},"autoReload":{"default":{},"description":"Configures automatic reload of code on edit.","properties":{"enable":{"default":false,"description":"Automatically reload code on edit.","type":"boolean"},"exclude":{"default":["**/.git/**","**/.metadata/**","**/__pycache__/**","**/node_modules/**","**/site-packages/**"],"description":"Glob patterns of paths to exclude from auto reload.","items":{"type":"string"},"type":"array"},"include":{"default":["**/*.py","**/*.pyw"],"description":"Glob patterns of paths to include in auto reload.","items":{"type":"string"},"type":"array"}},"type":"object"},"console":{"default":"integratedTerminal","description":"Where to launch the debug target: internal console, integrated terminal, or external terminal.","enum":["externalTerminal","integratedTerminal","internalConsole"]},"consoleTitle":{"default":"Python Debug Console","description":"Display name of the debug console or terminal"},"cwd":{"default":"${workspaceFolder}","description":"Absolute path to the working directory of the program being debugged. Default is the root directory of the file (leave empty).","type":"string"},"debugAdapterPath":{"description":"Path (fully qualified) to the python debug adapter executable.","type":"string"},"django":{"default":false,"description":"Django debugging.","type":"boolean"},"env":{"additionalProperties":{"type":"string"},"default":{},"description":"Environment variables defined as a key value pair. Property ends up being the Environment Variable and the value of the property ends up being the value of the Env Variable.","type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Absolute path to a file containing environment variable definitions.","type":"string"},"gevent":{"default":false,"description":"Enable debugging of gevent monkey-patched code.","type":"boolean"},"host":{"default":"localhost","description":"IP address of the of the local debug server (default is localhost).","type":"string"},"jinja":{"default":null,"description":"Jinja template debugging (e.g. Flask).","enum":[false,null,true]},"justMyCode":{"default":true,"description":"Debug only user-written code.","type":"boolean"},"logToFile":{"default":false,"description":"Enable logging of debugger events to a log file.","type":"boolean"},"module":{"default":"","description":"Name of the module to be debugged.","type":"string"},"pathMappings":{"default":[],"items":{"label":"Path mapping","properties":{"localRoot":{"default":"${workspaceFolder}","label":"Local source root.","type":"string"},"remoteRoot":{"default":"","label":"Remote source root.","type":"string"}},"required":["localRoot","remoteRoot"],"type":"object"},"label":"Path mappings.","type":"array"},"port":{"default":0,"description":"Debug port (default is 0, resulting in the use of a dynamic port).","type":"number"},"program":{"default":"${file}","description":"Absolute path to the program.","type":"string"},"purpose":{"default":[],"description":"Tells extension to use this configuration for test debugging, or when using debug-in-terminal command.","items":{"enum":["debug-test","debug-in-terminal"],"enumDescriptions":["Use this configuration while debugging tests using test view or test debug commands.","Use this configuration while debugging a file using debug in terminal button in the editor."]},"type":"array"},"pyramid":{"default":false,"description":"Whether debugging Pyramid applications","type":"boolean"},"python":{"default":"${command:python.interpreterPath}","description":"Absolute path to the Python interpreter executable; overrides workspace configuration if set.","type":"string"},"pythonArgs":{"default":[],"description":"Command-line arguments passed to the Python interpreter. To pass arguments to the debug target, use \"args\".","items":{"type":"string"},"type":"array"},"redirectOutput":{"default":true,"description":"Redirect output.","type":"boolean"},"showReturnValue":{"default":true,"description":"Show return value of functions when stepping.","type":"boolean"},"stopOnEntry":{"default":false,"description":"Automatically stop after launch.","type":"boolean"},"subProcess":{"default":false,"description":"Whether to enable Sub Process debugging","type":"boolean"},"sudo":{"default":false,"description":"Running debug program under elevated permissions (on Unix).","type":"boolean"}}}},"deprecated":"Эта конфигурация скоро станет нерекомендуемой. Замените \"python\" на \"debugpy\", чтобы использовать новое расширение отладчика Python.","configurationSnippets":[],"label":"Python","languages":["python"],"type":"python","variables":{"pickProcess":"python.pickLocalProcess"},"when":"!virtualWorkspace && shellExecutionSupported","hiddenWhen":"true"}],"grammars":[{"language":"pip-requirements","path":"./syntaxes/pip-requirements.tmLanguage.json","scopeName":"source.pip-requirements"}],"jsonValidation":[{"fileMatch":".condarc","url":"./schemas/condarc.json"},{"fileMatch":"environment.yml","url":"./schemas/conda-environment.json"},{"fileMatch":"meta.yaml","url":"./schemas/conda-meta.json"}],"keybindings":[{"command":"python.execSelectionInTerminal","key":"shift+enter","when":"editorTextFocus && editorLangId == python && !findInputFocussed && !replaceInputFocussed && !jupyter.ownsSelection && !notebookEditorFocused && !isCompositeNotebook"},{"command":"python.execInREPL","key":"shift+enter","when":"config.python.REPL.sendToNativeREPL && editorLangId == python && editorTextFocus && !jupyter.ownsSelection && !notebookEditorFocused && !isCompositeNotebook"},{"command":"python.execInREPLEnter","key":"enter","when":"!config.interactiveWindow.executeWithShiftEnter && isCompositeNotebook && activeEditor == 'workbench.editor.repl' && !inlineChatFocused && !notebookCellListFocused"},{"command":"python.execInInteractiveWindowEnter","key":"enter","when":"!config.interactiveWindow.executeWithShiftEnter && isCompositeNotebook && activeEditor == 'workbench.editor.interactive' && !inlineChatFocused && !notebookCellListFocused"}],"languages":[{"aliases":["Jinja"],"extensions":[".j2",".jinja2"],"id":"jinja"},{"aliases":["pip requirements","requirements.txt"],"configuration":"./languages/pip-requirements.json","filenamePatterns":["**/*requirements*.{txt, in}","**/*constraints*.txt","**/requirements/*.{txt,in}","**/constraints/*.txt"],"filenames":["constraints.txt","requirements.in","requirements.txt"],"id":"pip-requirements"},{"filenames":[".condarc"],"id":"yaml"},{"filenames":[".flake8",".pep8",".pylintrc",".pypirc"],"id":"ini"},{"filenames":["Pipfile","poetry.lock","uv.lock"],"id":"toml"},{"filenames":["Pipfile.lock"],"id":"json"}],"menus":{"issue/reporter":[{"command":"python.reportIssue"}],"commandPalette":[{"category":"Python","command":"python.analysis.restartLanguageServer","title":"Перезапустить языковой сервер","when":"!virtualWorkspace && shellExecutionSupported && (editorLangId == python || notebookType == jupyter-notebook)"},{"category":"Python","command":"python.clearCacheAndReload","title":"Очистить кэш и перезагрузить окно","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.clearWorkspaceInterpreter","title":"Очистить параметр интерпретатора рабочей области","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.configureTests","title":"Настройка тестов","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.createEnvironment","title":"Создать среду...","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.createEnvironment-button","title":"Создать среду...","when":"false"},{"category":"Python","command":"python.createTerminal","title":"Создать терминал","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.execInTerminal","title":"Запустить файл Python в терминале","when":"!virtualWorkspace && shellExecutionSupported && editorLangId == python"},{"category":"Python","command":"python.execInTerminal-icon","icon":"$(play)","title":"Запуск файла Python","when":"false"},{"category":"Python","command":"python.execInDedicatedTerminal","icon":"$(play)","title":"Запустить файл Python на выделенном терминале","when":"false"},{"category":"Python","command":"python.execSelectionInDjangoShell","title":"Запустить выделение или строку в оболочке Django","when":"!virtualWorkspace && shellExecutionSupported && editorLangId == python"},{"category":"Python","command":"python.execSelectionInTerminal","title":"Запустить выделение или строку в терминале Python","when":"!virtualWorkspace && shellExecutionSupported && editorLangId == python"},{"category":"Python","command":"python.execInREPL","title":"Запуск выделения или строки в собственном Python REPL","when":"false"},{"category":"Python","command":"python.reportIssue","title":"Сообщить о проблеме...","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Test","command":"testing.reRunFailTests","icon":"$(run-errors)","title":"Повторить запуск неудачных тестов","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.setInterpreter","title":"Выбор интерпретатора","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.startREPL","title":"Запуск REPL для терминала","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.startNativeREPL","title":"Запуск собственной REPL для REPL","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.viewLanguageServerOutput","enablement":"python.hasLanguageServerOutputChannel","title":"Показать выходные данные языкового сервера","when":"!virtualWorkspace && shellExecutionSupported"},{"category":"Python","command":"python.viewOutput","title":"Показать выходные данные","when":"!virtualWorkspace && shellExecutionSupported"}],"editor/content":[{"group":"Python","command":"python.createEnvironment-button","when":"showCreateEnvButton && resourceLangId == pip-requirements && !virtualWorkspace && shellExecutionSupported && !inDiffEditor && !isMergeResultEditor && pythonDepsNotInstalled"},{"group":"Python","command":"python.createEnvironment-button","when":"showCreateEnvButton && resourceFilename == pyproject.toml && pipInstallableToml && !virtualWorkspace && shellExecutionSupported  && !inDiffEditor && !isMergeResultEditor && pythonDepsNotInstalled"}],"editor/context":[{"submenu":"python.run","group":"Python","when":"editorLangId == python && !virtualWorkspace && shellExecutionSupported && isWorkspaceTrusted && !inChat  && notebookType != jupyter-notebook"},{"submenu":"python.runFileInteractive","group":"Jupyter2","when":"editorLangId == python && !virtualWorkspace && shellExecutionSupported && !isJupyterInstalled && isWorkspaceTrusted && !inChat"}],"python.runFileInteractive":[{"command":"python.installJupyter","group":"Jupyter2","when":"resourceLangId == python && !virtualWorkspace && shellExecutionSupported"}],"python.run":[{"command":"python.execInTerminal","group":"Python","when":"resourceLangId == python && !virtualWorkspace && shellExecutionSupported"},{"command":"python.execSelectionInDjangoShell","group":"Python","when":"editorHasSelection && editorLangId == python && python.isDjangoProject && !virtualWorkspace && shellExecutionSupported"},{"command":"python.execSelectionInTerminal","group":"Python","when":"!config.python.REPL.sendToNativeREPL && editorFocus && editorLangId == python && !virtualWorkspace && shellExecutionSupported"},{"command":"python.execInREPL","group":"Python","when":"editorFocus && editorLangId == python && !virtualWorkspace && shellExecutionSupported && config.python.REPL.sendToNativeREPL"}],"editor/title/run":[{"command":"python.execInTerminal-icon","group":"navigation@0","title":"Запуск файла Python","when":"resourceLangId == python && !isInDiffEditor && !virtualWorkspace && shellExecutionSupported"},{"command":"python.execInDedicatedTerminal","group":"navigation@0","title":"Запустить файл Python на выделенном терминале","when":"resourceLangId == python && !isInDiffEditor && !virtualWorkspace && shellExecutionSupported"}],"explorer/context":[{"command":"python.execInTerminal","group":"Python","when":"resourceLangId == python && !virtualWorkspace && shellExecutionSupported"}],"file/newFile":[{"command":"python.createNewFile","group":"file","when":"!virtualWorkspace"}],"view/title":[{"command":"testing.reRunFailTests","when":"view == workbench.view.testing && hasFailedTests && !virtualWorkspace && shellExecutionSupported","group":"navigation@1"}]},"submenus":[{"id":"python.run","label":"Запустить Python","icon":"$(play)"},{"id":"python.runFileInteractive","label":"Запустить в интерактивном окне"}],"viewsWelcome":[{"view":"testing","contents":"Configure a test framework to see your tests here.\n[Configure Python Tests](command:python.configureTests)","when":"!virtualWorkspace && shellExecutionSupported"}